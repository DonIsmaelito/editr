# Findr Environment Variables
# Copy to .env and fill in your keys:  cp .env.example .env

# --- Required ---
OPENAI_API_KEY=sk-...                      # OpenAI — classification, moment finding, embeddings, vision
CONVEX_URL=https://your-project.convex.cloud  # Convex — real-time results + vector search

# --- Browser Infrastructure (needed for visual verification + TikTok/X) ---
DAYTONA_API_KEY=...                        # Daytona — ephemeral sandboxes for headless screenshots
DAYTONA_TARGET=us                          # Daytona region: "us" or "eu"
BROWSER_USE_API_KEY=bu_...                 # Browser Use Cloud — TikTok/X search via Skills
BROWSER_USE_PROFILE_ID=                    # Optional Browser Use profile ID (logged-in session for blocked sites)
BROWSER_USE_OP_VAULT_ID=                   # Optional 1Password vault ID shared with Browser Use integration

# --- Browser Use Skill IDs (auto-created on first use, then paste here) ---
# After first run, the logs will print skill IDs. Paste them here to avoid re-creating ($2 each).
TIKTOK_SEARCH_SKILL_ID=                    # Created automatically on first TikTok search
TWITTER_SEARCH_SKILL_ID=                   # Created automatically on first X/Twitter search
TWITTER_AUTH_TOKEN=                        # Optional x.com auth_token cookie value (if skill requires cookie params)
TWITTER_CT0=                               # Optional x.com ct0 cookie value (if skill requires cookie params)

# --- Optional ---
GROQ_API_KEY=gsk_...                       # Groq Whisper — transcription fallback
APIFY_API_TOKEN=apify_api_...              # Apify — alternative TikTok/X search (legacy)
